@using ImpulsaDBA.Shared.DTOs
@using ImpulsaDBA.Shared.Requests
@using ImpulsaDBA.Client.Services
@using System.ComponentModel.DataAnnotations
@using Microsoft.JSInterop
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@inject CalendarioService CalendarioService
@inject AsignaturaService AsignaturaService
@inject AuthenticationStateProvider AuthStateProvider
@inject IJSRuntime JS

@if (Mostrar)
{
    <div class="modal-overlay" 
         @onclick="CerrarModal"
         role="presentation">
        <div id="modal-clase-virtual-container" class="modal-container" 
             @onclick:stopPropagation="true" @onkeydown="OnModalKeyDown" role="dialog"
             aria-modal="true"
             aria-labelledby="modal-clase-virtual-title">
            <div class="modal-header">
                <h2 id="modal-clase-virtual-title">@(modoSoloLectura ? "Ver" : (esModoEdicion ? "Editar" : "Crear")) Clase Virtual</h2>
                <button class="btn-cerrar" @onclick="CerrarModal" title="Cerrar">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>

            <div class="modal-body">
                <EditForm Model="actividad" OnValidSubmit="GuardarActividad">
                    <DataAnnotationsValidator />
                    
                    @if (modoSoloLectura && ActividadEditar != null && ActividadEditar.FechaCreacion.HasValue)
                    {
                        <div class="alert alert-info mb-3">
                            <i class="bi bi-calendar-plus"></i>
                            <strong>Fecha de creación:</strong> @ActividadEditar.FechaCreacion.Value.ToString("dd/MM/yyyy HH:mm")
                        </div>
                    }
                    
                    <div class="form-check form-switch mb-3">
                        <input class="form-check-input" type="checkbox" role="switch" id="flexSwitchCheckDefault"
                               @bind="actividad.ActividadActiva" disabled="@modoSoloLectura">
                        <label class="form-check-label" for="flexSwitchCheckDefault">
                            @(actividad.ActividadActiva ? "Visible a los estudiantes" : "No visible a los estudiantes")
                        </label>
                    </div>

                    <div class="mb-3">
                        <label for="fecha-actividad" class="form-label">Fecha de Calendario</label>
                        <input type="datetime-local" id="fecha-entrega" class="form-control"
                               aria-describedby="validation-fecha-entrega"
                               @bind="actividad.FechaPublicacion" 
                               min="@DateTime.Today.AddDays(1).ToString("yyyy-MM-ddTHH:mm")"
                               disabled="@modoSoloLectura" />
                        <ValidationMessage Id="validation-fecha-entrega" For="@(() => actividad.FechaPublicacion)" />
                        @if (!esModoEdicion && !modoSoloLectura && actividad.FechaPublicacion.HasValue && actividad.FechaPublicacion.Value.Date <= DateTime.Today)
                        {
                            <small class="text-danger">Solo se pueden crear actividades para días futuros (a partir de mañana).</small>
                        }
                    </div>

                    <div class="form-group mb-3">
                        <label for="titulo-actividad">Título</label>
                        <input type="text" class="form-control" id="titulo-actividad"
                               aria-describedby="validation-titulo-actividad"
                               @bind="actividad.Titulo" disabled="@modoSoloLectura" />
                        <ValidationMessage Id="validation-titulo-actividad" For="@(() => actividad.Titulo)" />
                    </div>

                    <div class="form-group mb-3">
                        <label for="descripcion-actividad">Descripción</label>
                        <textarea class="form-control" id="descripcion-actividad" rows="3"
                                  aria-describedby="validation-descripcion-actividad"
                                  @bind="actividad.Descripcion" disabled="@modoSoloLectura"></textarea>
                        <ValidationMessage Id="validation-descripcion-actividad" For="@(() => actividad.Descripcion)" />
                    </div>

                    <div class="mb-3">
                        <label for="link-actividad" class="form-label">Link</label>
                        <input type="url" id="link-actividad" class="form-control"
                               aria-describedby="validation-link-actividad"
                               @bind="actividad.Link" placeholder="https://..."
                               disabled="@modoSoloLectura" />
                        <ValidationMessage Id="validation-link-actividad" For="@(() => actividad.Link)" />
                    </div>

                    @if (!string.IsNullOrEmpty(MensajeProcesos))
                    {
                        <div class="alert alert-info">
                            @MensajeProcesos
                        </div>
                    }

                    <div class="modal-footer">
                        @if (modoSoloLectura)
                        {
                            @* Filtro por grupo: solo visualización, sin botones Cerrar ni Editar (se cierra con la X del header) *@
                        }
                        else
                        {
                            <button type="button" class="btn btn-danger" @onclick="CerrarModal">Cancelar</button>
                            <button type="submit" class="btn btn-primary">Guardar Actividad</button>
                        }
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
}

<style>
    .modal-overlay {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background-color: rgba(0, 0, 0, 0.5);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 1000;
        animation: fadeIn 0.2s ease;
    }

    @@keyframes fadeIn {
        from { opacity: 0; }
        to { opacity: 1; }
    }

    .modal-container {
        background-color: var(--color-bg-primary);
        border-radius: var(--border-radius-lg);
        width: 90%;
        max-width: 600px;
        max-height: 80vh;
        display: flex;
        flex-direction: column;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.3);
        animation: slideUp 0.3s ease;
    }

    @@keyframes slideUp {
        from {
            transform: translateY(20px);
            opacity: 0;
        }
        to {
            transform: translateY(0);
            opacity: 1;
        }
    }

    .modal-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 1.5rem;
        border-bottom: 1px solid var(--color-border);
    }

    .modal-header h3 {
        margin: 0;
        font-size: 1.5rem;
        font-weight: 600;
        color: var(--color-text-primary);
    }

    .btn-cerrar {
        background: none;
        border: none;
        font-size: 1.5rem;
        color: var(--color-text-secondary);
        cursor: pointer;
        padding: 0.25rem;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: color var(--transition-fast);
    }

    .btn-cerrar:hover {
        color: var(--color-text-primary);
    }

    .modal-body {
        padding: 1.5rem;
        overflow-y: auto;
        flex: 1;
    }

    .modal-footer {
        display: flex;
        justify-content: flex-end;
        gap: 1rem;
        padding: 1.5rem;
        border-top: 1px solid var(--color-border);
    }

    .btn {
        padding: 0.75rem 1.5rem;
        border: none;
        border-radius: var(--border-radius-md);
        font-weight: 500;
        cursor: pointer;
        transition: all var(--transition-fast);
    }

    .btn-primary {
        background-color: var(--color-primary);
        color: var(--color-text-white);
    }

    .btn-primary:hover:not(:disabled) {
        background-color: var(--color-primary-dark);
    }

    .btn-secondary {
        background-color: var(--color-secondary);
        color: var(--color-text-white);
    }

    .btn-secondary:hover {
        background-color: var(--color-secondary-dark);
    }

    .form-control {
        width: 100%;
        padding: 0.5rem;
        border: 1px solid var(--color-border);
        border-radius: var(--border-radius-sm);
        font-size: 1rem;
    }

    .form-label {
        display: block;
        margin-bottom: 0.5rem;
        font-weight: 500;
        color: var(--color-text-primary);
    }

    .alert {
        padding: 1rem;
        border-radius: var(--border-radius-md);
        margin-bottom: 1rem;
    }

    .alert-info {
        background-color: var(--color-info-light);
        color: var(--color-info-dark);
    }
</style>

@code {
    [Parameter] public bool Mostrar { get; set; }
    [Parameter] public DateTime FechaSeleccionada { get; set; }
    [Parameter] public int IdAsignacionAcademica { get; set; }
    [Parameter] public ActividadCalendarioDto? ActividadEditar { get; set; }
    [Parameter] public bool ModoSoloLectura { get; set; } = false;
    [Parameter] public EventCallback OnCerrar { get; set; }
    [Parameter] public EventCallback OnActividadGuardada { get; set; }

    private CrearActividadRequest actividad = new();
    private string MensajeProcesos = "";
    private bool esModoEdicion => ActividadEditar != null;
    private bool modoSoloLectura = false;

    protected override async Task OnParametersSetAsync()
    {
        if (Mostrar)
        {
            modoSoloLectura = ModoSoloLectura;
            
            if (ActividadEditar != null)
            {
                // Modo edición: cargar datos completos de la actividad
                try
                {
                    var actividadCompleta = await CalendarioService.ObtenerActividadCompleta(ActividadEditar.Id);
                    
                    actividad = new CrearActividadRequest
                    {
                        Titulo = actividadCompleta.Titulo ?? ActividadEditar.Titulo ?? "",
                        Descripcion = actividadCompleta.Descripcion ?? "",
                        FechaPublicacion = actividadCompleta.FechaPublicacion ?? ActividadEditar.FechaInicio,
                        ActividadActiva = actividadCompleta.ActividadActiva,
                        Link = actividadCompleta.Descripcion // El link puede estar en descripción
                    };
                }
                catch (Exception ex)
                {
                    Console.WriteLine($"Error al cargar actividad completa: {ex.Message}");
                    // Fallback a datos básicos
                    actividad = new CrearActividadRequest
                    {
                        FechaPublicacion = ActividadEditar.FechaInicio,
                        ActividadActiva = !ActividadEditar.Eliminado
                    };
                }
            }
            else
            {
                actividad = new CrearActividadRequest
                {
                    FechaPublicacion = FechaSeleccionada,
                    ActividadActiva = true
                };
            }
            MensajeProcesos = "";
        }
    }

    private void HabilitarEdicion()
    {
        modoSoloLectura = false;
        StateHasChanged();
    }

    private async Task GuardarActividad()
    {
        try
        {
            // Validar que tenemos un IdAsignacionAcademica válido
            if (IdAsignacionAcademica <= 0)
            {
                MensajeProcesos = "Error: No se ha seleccionado una asignación académica válida";
                Console.WriteLine("❌ Error: IdAsignacionAcademica es inválido o cero");
                return;
            }

            MensajeProcesos = esModoEdicion ? "Actualizando actividad..." : "Guardando actividad...";
            
            if (esModoEdicion && ActividadEditar != null)
            {
                // Obtener UsuarioId del usuario actual
                var authState = await AuthStateProvider.GetAuthenticationStateAsync();
                var usuarioIdClaim = authState?.User?.FindFirst(ClaimTypes.NameIdentifier)?.Value;
                if (string.IsNullOrEmpty(usuarioIdClaim) || !int.TryParse(usuarioIdClaim, out int usuarioId))
                {
                    MensajeProcesos = "Error: No se pudo identificar al usuario actual";
                    return;
                }

                // Modo actualización
                var requestActualizar = new ActualizarActividadRequest
                {
                    Id = ActividadEditar.Id, // ID de tab.asignacion_academica_recurso
                    ActividadActiva = actividad.ActividadActiva,
                    FechaPublicacion = actividad.FechaPublicacion,
                    Titulo = actividad.Titulo,
                    Descripcion = actividad.Descripcion,
                    Link = actividad.Link,
                    UsuarioId = usuarioId
                };
                
                Console.WriteLine($"📤 Actualizando actividad con ID: {requestActualizar.Id}, UsuarioId: {usuarioId}");
                
                try
                {
                    var resultado = await CalendarioService.ActualizarActividad(requestActualizar);
                    
                    Console.WriteLine($"✅ Clase Virtual actualizada exitosamente: {resultado}");
                    MensajeProcesos = "Actividad actualizada correctamente";
                }
                catch (UnauthorizedAccessException ex)
                {
                    Console.WriteLine($"❌ No autorizado: {ex.Message}");
                    MensajeProcesos = $"No autorizado: {ex.Message}";
                }
                catch (Exception ex)
                {
                    Console.WriteLine($"❌ Error al actualizar: {ex.Message}");
                    MensajeProcesos = $"Error al actualizar: {ex.Message}";
                }
            }
            else
            {
                // Modo creación
                // Obtener información del periodo actual
                var periodoInfo = await AsignaturaService.ObtenerPeriodoActual();
                int anioId = int.Parse(periodoInfo.Anio);
                int periodoId = int.Parse(periodoInfo.Periodo);
                
                // Construir el request
                var request = new CrearActividadCompletaRequest
                {
                    ActividadActiva = actividad.ActividadActiva,
                    FechaPublicacion = actividad.FechaPublicacion,
                    Titulo = actividad.Titulo,
                    Descripcion = actividad.Descripcion,
                    Link = actividad.Link,
                    TipoActividadId = 14, // Clase Virtual
                    AsignacionAcademicaId = IdAsignacionAcademica,
                    PeriodoId = periodoId,
                    AnioId = anioId
                };
                
                await CalendarioService.CrearActividad(request);
                
                MensajeProcesos = "Actividad guardada correctamente";
            }
            
            await Task.Delay(1000);
            
            if (OnActividadGuardada.HasDelegate)
            {
                await OnActividadGuardada.InvokeAsync();
            }
            
            await CerrarModal();
        }
        catch (Exception ex)
        {
            MensajeProcesos = $"Error al guardar la actividad: {ex.Message}";
            Console.WriteLine($"Error al guardar actividad: {ex.Message}");
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (Mostrar)
        {
            try { await JS.InvokeVoidAsync("impulsaAccActivateModalTrap", "modal-clase-virtual-container"); } catch { }
        }
    }

    private async Task CerrarModal()
    {
        try { await JS.InvokeVoidAsync("impulsaAccDeactivateModalTrap"); } catch { }
        if (OnCerrar.HasDelegate)
        {
            await OnCerrar.InvokeAsync();
        }
    }

    private async Task OnModalKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Escape")
        {
            await CerrarModal();
        }
    }
}
